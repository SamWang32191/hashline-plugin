{
  "name": "@w32191/hashline-plugin",
  "version": "0.1.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "OpenCode plugin that adds hashline-aware read and edit behavior.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamWang32191/hashline-plugin"
  },
  "homepage": "https://github.com/SamWang32191/hashline-plugin#readme",
  "bugs": {
    "url": "https://github.com/SamWang32191/hashline-plugin/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepack": "bun run build",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.3.13"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
